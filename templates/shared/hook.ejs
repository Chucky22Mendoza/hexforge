import { use<%= name %>Store } from "../store/use<%= name %>Store";
import type { <%= name %> } from "../domain/<%= name.toLowerCase() %>";
import { API<%= name %>Repository } from "../infrastructure/API<%= name %>Repository";
import type { <%= name %>Repository } from "../repository/<%= name %>Repository";

interface Use<%= name %>Hook {
  performGet: () => Promise<void>;
  performGetOne: (id: string) => Promise<<%= name %> | null>;
  performCreate: (data: <%= name %>) => Promise<boolean>;
  performUpdate: (data: <%= name %>) => Promise<boolean>;
  performDelete: (id: string) => Promise<boolean>;
}

export const use<%= name %> = (): Use<%= name %>Hook => {
  const setData = use<%= name %>Store((state) => state.setData);
  const setLoading = use<%= name %>Store((state) => state.setLoading);
  const setError = use<%= name %>Store((state) => state.setError);
  const <%= name.toLowerCase() %>Repository: <%= name %>Repository = new API<%= name %>Repository();

  const performGet = async () => {
    setLoading(true);
    try {
      const response = await <%= name.toLowerCase() %>Repository.getAll();
      setData(response?.data ?? []);
    } catch (error: any) {
      setError(error);
    } finally {
      setLoading(false);
    }
  };

  const performGetOne = async (id: string): Promise<<%= name %> | null> => {
    setLoading(true);
    try {
      const response = await <%= name.toLowerCase() %>Repository.getById(id);
      return response?.data ?? null;
    } catch (error: any) {
      setError(error);
      return null;
    } finally {
      setLoading(false);
    }
  };

  const performCreate = async (data: <%= name %>): Promise<boolean> => {
    setLoading(true);
    try {
      const response = await <%= name.toLowerCase() %>Repository.create(data);
      return response.success;
    } catch (error: any) {
      setError(error);
      return false;
    } finally {
      setLoading(false);
    }
  };

  const performUpdate = async (data: <%= name %>): Promise<boolean> => {
    setLoading(true);
    try {
      const response = await <%= name.toLowerCase() %>Repository.update(data);
      return response.success;
    } catch (error: any) {
      setError(error);
      return false;
    } finally {
      setLoading(false);
    }
  };

  const performDelete = async (id: string): Promise<boolean> => {
    setLoading(true);
    try {
      const response = await <%= name.toLowerCase() %>Repository.delete(id);
      return response.success;
    } catch (error: any) {
      setError(error);
      return false;
    } finally {
      setLoading(false);
    }
  };

  return {
    performGet,
    performGetOne,
    performCreate,
    performUpdate,
    performDelete,
  };
};