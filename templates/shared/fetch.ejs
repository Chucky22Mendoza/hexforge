import type { ResponseWrapper } from "../modules/shared/types/response-wrapper";

interface FetchOptions extends RequestInit {
  headers?: HeadersInit;
}

export const fetchWithAuth = async <T>(
  url: string,
  options: FetchOptions = {},
): Promise<ResponseWrapper<T>> => {
  const updateOptions = { ...options };
  updateOptions.method = updateOptions.method ?? 'GET';

  const headers: any = {
    ...updateOptions.headers,
    cache: 'no-store',
  };

  if (!headers['Content-Type'] && !(updateOptions.body instanceof FormData)) {
    headers['Content-Type'] = 'application/json';
  } else if (headers['Content-Type'] === 'multipart/form-data') {
    delete headers['Content-Type'];
  }

  const newOptions = {
    ...updateOptions,
    headers,
  };

  const statusSuccess = [200, 201];
  const statusNotAuth = [401, 405];

  try {
    const response = await fetch(url, newOptions);

    if (statusSuccess.includes(response.status)) {
      if (headers['Content-Type'] !== 'application/json') {
        const blob = await response.blob();
        return Promise.resolve({
          message: 'File downloaded successfully.',
          success: true,
          data: blob as T,
        });
      }

      const { message, data, meta } = await response.json();
      return Promise.resolve({
        message,
        success: true,
        data: data as T,
        meta: meta ?? undefined,
      });
    }

    if (statusNotAuth.includes(response.status)) {
      // Force signout via endpoint or hard redirect
      // Using window.location to ensure full client-side redirect independent of React context
      if (typeof window !== 'undefined') {
        window.location.href = '/logout';
      }

      return Promise.resolve({
        message: 'Session expired or invalid. Redirecting...',
        success: false,
      });
    }

    const { message } = await response.json();
    return Promise.resolve({
      message,
      success: false,
    });
  } catch (error: unknown) {
    console.error('[fetchWithAuth] Unexpected error:', error);
    return Promise.resolve({
      message: 'Unexpected error. Please try again.',
      success: false,
    });
  }
};
