<% if (name === 'Home') { %>
/* ------------------------------------------------------------------
   Home Module - Advanced CSS Module Styling
   Used when Tailwind is NOT installed.
   ------------------------------------------------------------------ */
.container {
  min-height: 100vh;
  background-color: #171717; /* neutral-900 */
  color: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

.content {
  max-width: 48rem;
  text-align: center;
}

.icon {
  font-size: 3.75rem;
  margin-bottom: 1rem;
}

.title {
  font-size: 3rem;
  font-weight: 900;
  letter-spacing: -0.025em;
  color: #eab308; /* yellow-500 */
  margin: 0;
  line-height: 1;
}

@media (min-width: 640px) {
  .title {
    font-size: 4.5rem;
  }
}

.subtitle {
  font-size: 1.125rem;
  color: #a3a3a3; /* neutral-400 */
  font-weight: 300;
  margin-top: 2rem;
}

@media (min-width: 640px) {
  .subtitle {
    font-size: 1.5rem;
  }
}

.actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  margin-top: 2rem;
}

.primaryButton {
  padding: 0.75rem 1.75rem;
  border-radius: 9999px;
  background-color: #eab308;
  color: #171717;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.2s ease;
  border: none;
  cursor: pointer;
}

.primaryButton:hover {
  background-color: #facc15; /* yellow-400 */
  transform: translateY(-2px);
}

.secondaryButton {
  padding: 0.75rem 1.75rem;
  border-radius: 9999px;
  background-color: transparent;
  color: #ffffff;
  border: 1px solid #404040; /* neutral-700 */
  font-weight: 600;
  transition: all 0.2s ease;
  cursor: pointer;
}

.secondaryButton:hover {
  background-color: #262626; /* neutral-800 */
}
<% } else { %>
/* ------------------------------------------------------------------
   <%= name %> Module - Basic CSS Module
   ------------------------------------------------------------------ */
.container {
  padding: 1.5rem;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

.title {
  font-size: 1.5rem;
  font-weight: bold;
  color: #111827;
  margin-bottom: 0.5rem;
}

.subtitle {
  color: #4b5563;
  margin: 0;
}
<% } %>
